


<style>
    :root {
        --bg: #f4f6fb;
        --card: #ffffff;
        --text: #1f2a37;
        --muted: #6b7280;
        --line: #e7ebf3;
        --blue: #2f7cf6;
        --blue-2: #69a7ff;
        --green: #22c55e;
        --amber: #f59e0b;
        --red: #ef4444;
        --shadow: 0 10px 30px rgba(31,42,55,.08);
        --radius: 14px;
    }

    * {
        box-sizing: border-box
    }

    body {
        
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Helvetica Neue", Helvetica, "Noto Sans", "Liberation Sans", sans-serif;
        color: var(--text);
        background: radial-gradient(900px 450px at 20% 10%, #e9f1ff 0%, rgba(233,241,255,0) 70%), radial-gradient(900px 450px at 90% 0%, #efeaff 0%, rgba(239,234,255,0) 60%), var(--bg);
    }

    .wrap {
        --max-width: 1180px;
        margin: 26px auto;
        padding: 0 18px 34px;
    }

   
    .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
    }

    .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .card-pad {
        padding: 14px 16px;
    }

    /* ---- Top summary cards ---- */
    .summary {
        grid-column: span 3;
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 86px;
    }

        .summary .label {
            font-size: 13px;
            font-weight: 700;
            color: #3b4556;
            opacity: .9;
        }

        .summary .value {
            display: flex;
            align-items: baseline;
            gap: 10px;
            margin-top: 2px;
        }

        .summary .amt {
            font-size: 22px;
            font-weight: 800;
            letter-spacing: .2px;
        }

        .summary .sub {
            font-size: 12px;
            color: var(--muted);
            display: flex;
            gap: 6px;
            align-items: center;
        }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid var(--line);
        background: #fbfcff;
    }

        .pill.green {
            color: #0b7a2a;
            background: #eafaf0;
            border-color: #c9f1d6;
        }

        .pill.amber {
            color: #8a5a00;
            background: #fff6e6;
            border-color: #ffe2b4;
        }

        .pill.red {
            color: #8a1111;
            background: #ffeaea;
            border-color: #ffc2c2;
        }

    /* ---- Section headers ---- */
    .card-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 12px 16px;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
    }

        .card-head h3 {
            margin: 0;
            font-size: 14px;
            font-weight: 800;
            color: #2b3443;
        }

        .card-head .meta {
            font-size: 12px;
            color: var(--muted);
            font-weight: 600;
        }

    /* ---- Layout blocks ---- */
    .trend {
        grid-column: span 6;
    }

    .stock {
        grid-column: span 6;
    }

    .aging {
        grid-column: span 12;
    }

    .insights {
        grid-column: span 5;
    }

    .table {
        grid-column: span 12;
    }

    /* ---- Chart helpers ---- */
    .chart {
        padding: 10px 12px 12px;
    }

    .svg {
        width: 100%;
        height: auto;
        display: block;
    }

    .legend {
        display: flex;
        gap: 14px;
        align-items: center;
        padding: 0 16px 12px;
        color: var(--muted);
        font-size: 12px;
        font-weight: 600;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 3px;
        display: inline-block;
        margin-right: 6px;
    }

    /* ---- Insights list ---- */
    .insight-list {
        padding: 12px 16px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .insight {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 10px 12px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: #fbfcff;
    }

    .warn {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        background: #fff6e6;
        border: 1px solid #ffe2b4;
        color: #8a5a00;
        font-weight: 900;
        flex: 0 0 auto;
    }

    .insight p {
        margin: 2px 0 0;
        font-size: 13px;
        color: #3b4556;
        font-weight: 650;
    }

    /* ---- Table ---- */
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    thead th {
        text-align: left;
        padding: 12px 14px;
        color: #3b4556;
        font-weight: 800;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
    }

    tbody td {
        padding: 5px 14px;
        border-bottom: 1px solid var(--line);
        color: #2b3443;
        --font-weight: 650;
    }

    tbody tr:hover td {
        background: #fbfcff;
    }

    .risk {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
        color: #3b4556;
    }

        .risk .r-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: var(--muted);
        }

        .risk.high .r-dot {
            background: var(--red);
        }

        .risk.med .r-dot {
            background: var(--amber);
        }

        .risk.low .r-dot {
            background: var(--green);
        }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 12px;
        border-radius: 10px;
        border: 1px solid var(--line);
        background: #f7faff;
        font-weight: 800;
        font-size: 12px;
        color: #1f3b7a;
        cursor: pointer;
        user-select: none;
    }

        .btn.call {
            background: #eaf2ff;
            border-color: #cfe0ff;
            color: #1b4fbf;
        }

        .btn.follow {
            background: #fff6e6;
            border-color: #ffe2b4;
            color: #8a5a00;
        }

        .btn.remind {
            background: #eafaf0;
            border-color: #c9f1d6;
            color: #0b7a2a;
        }

    /* ---- Responsiveness ---- */
    @@media (max-width: 1020px) {
        .summary

    {
        grid-column: span 6;
    }

    .trend, .aging {
        grid-column: span 12;
    }

    .stock, .insights {
        grid-column: span 12;
    }

    }
    @@media (max-width: 560px) {
        .summary

    {
        grid-column: span 12;
    }

    .title {
        font-size: 24px;
    }

    thead {
        display: none;
    }

    tbody tr {
        display: grid;
        grid-template-columns: 1fr;
    }

    tbody td {
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

        tbody td::before {
            content: attr(data-label);
            color: var(--muted);
            font-weight: 800;
        }

    }
    .sortable-header{
        cursor: pointer;
    }
</style>


<div id="id-parent-analytics">
    <div class="wrap">
        <div class="text-xl font-semibold mb-3"><span>Analytics</span></div>

        <div class="grid">
            <!-- Summary Cards -->
            <div class="card summary card-pad">
                <div class="label">Total Sales This Month</div>
                <div class="value" id="total-sales-this-month-tile">
                    <div class="amt" id="total-sales-this-month-val"></div>
                    <span class="pill green" id="total-sales-this-month-percentage">▲ 0%</span>
                </div>
            </div>

            <div class="card summary card-pad">
                <div class="label">Expected Cash Inflow</div>
                <div class="value">
                    <div class="amt" id="expected-cash-flow-amt"></div>
                    <div class="sub">Due Soon</div>
                </div>
            </div>

            <div class="card summary card-pad">
                <div class="label">Expenses Upcoming Month</div>
                <div class="value">
                    <div class="amt" id="expenses-upcoming-month-amt"></div>
                    <span class="sub" id="expenses-upcoming-month"></span>
                </div>
            </div>

            <div class="card summary card-pad">
                <div class="label">Receivables At Risk</div>
                <div class="value">
                    <div class="amt" style="color:var(--red)" id="receivables-at-risk-amt"></div>
                    <div class="sub" style="color:#b42318;font-weight:800;">High Risk</div>
                </div>
            </div>

            <!-- Sales Trend -->
            <div class="card trend" style="height:370px;">
                <div class="card-head">
                    <h3>Sales Trend <span class="meta">(Last 12 Months)</span></h3>
                </div>
                <div class="chart" style="height:300px;">
                    <canvas id="salesTrendChart"></canvas>
                </div>
            </div>

            <!-- Stock Status -->
            <div class="card stock">
                <div class="card-head" id="landing-cost-trend-header">
                    <h3 style="white-space: nowrap;margin-right: 40px;">Landing Cost Trend</h3>
                    <div class="d-flex align-items-center gap-2">
                        <label for="lanidng-cost-trend-itemCode" class="small text-muted mb-0">Product</label>
                        <select id="lanidng-cost-trend-itemCode" name="lanidng-cost-trend-itemCode" class="form-select form-select-sm product-select">
                            
                        </select>
                    </div>
                </div>
                <div class="chart" style="height:295px;">
                    <canvas id="stockStatusChart"></canvas>
                </div>
               
            </div>

            <!-- Receivables Aging -->
            <div class="card aging">
                <div class="card-head">
                    <h3>Receivables Aging</h3>
                </div>
                <div class="chart">
                    <canvas id="agingChart"></canvas>
                </div>
            </div>

            <!-- Receivables Priority List -->
            <div class="card table">
                <div style="overflow:auto;">
                    <table id="receivablesTable">
                        <thead class="table-light">
                            <tr>
                                <th class="fw-bold fs-6 py-3" style="width: 34%;">Receivables Priority List</th>
                                <th class="text-end px-3 sortable-header" data-sort="outstanding">Outstanding</th>
                                <th class="text-center px-3 sortable-header" data-sort="payment">Expected Payment</th>
                                <th class="text-center px-3 sortable-header" data-sort="risk">Risk Level</th>
                                <th class="text-center px-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
<script>
    GetAIAnalyticsSummary();
    GetAIAnalyticsSalesTrend();
    GetAIAnalyticsLandingCostTrendSelectionItems();
    GetAIAnalyticsReceivablesAging();
    GetAIAnalyticsReceivablesPriorityList();

    function GetAIAnalyticsSummary(){
        var apiData = {
            UserId: ScriptUser.USERID
        }
        $.ajax({
            url: RequestBasePath + '/Analytics/GetAIAnalyticsSummary',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                if(outData["SalesGrowth"] > 0){
                     $('#total-sales-this-month-tile').html('<div class="amt" id="total-sales-this-month-val">'+convertToIndianFormat(outData["ProjectedSales"])+'</div><span class="pill green" id="total-sales-this-month-percentage">▲ ' + Number(outData["SalesGrowth"]).toFixed(2) +'%</span>');
                }else{
                    $('#total-sales-this-month-tile').html('<div class="amt" id="total-sales-this-month-val">' + convertToIndianFormat(outData["ProjectedSales"]) + '</div><span class="pill red" id="total-sales-this-month-percentage">▼ ' + Number(outData["SalesGrowth"]).toFixed(2) +'%</span>');
                }
                $('#expected-cash-flow-amt').text(convertToIndianFormat(outData["ExpectedCash"]));
                $('#expenses-upcoming-month-amt').text(convertToIndianFormat(outData["UpcomingExpense"]));
                $('#expenses-upcoming-month').text(outData["NextMonth"]);
                $('#receivables-at-risk-amt').text(convertToIndianFormat(outData["AtRiskKPI"]))
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }

    function GetAIAnalyticsSalesTrend(){
        var apiData = {
            UserId: ScriptUser.USERID
        }
        $.ajax({
            url: RequestBasePath + '/Analytics/GetAIAnalyticsSalesTrend',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                var labels = outData["ChartLabels"];
                var data = outData["ChartData"];
                var forecastIdx = outData["ForecastIndex"];
                initSalesTrendChart(labels, data, forecastIdx)
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }

    function initSalesTrendChart(labels, data, forecastIdx) {
        const canvas = document.getElementById('salesTrendChart');
        if (!canvas) return;

        const ctx = canvas.getContext('2d');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Monthly Sales',
                    data: data,
                    fill: true,
                    tension: 0,
                    borderColor: '#1f66c4',
                    borderWidth: 2,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#1e40af',
                    pointBorderWidth: 1,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    backgroundColor: function (context) {
                        const chart = context.chart;
                        const chartCtx = chart.ctx;
                        const chartArea = chart.chartArea;
                        if (!chartArea) return null;

                        const gradient = chartCtx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
                        gradient.addColorStop(0, 'rgba(30, 102, 196, 0.01)');
                        gradient.addColorStop(1, 'rgba(30, 102, 196, 0.4)');
                        return gradient;
                    },
                    segment: {
                        borderDash: context => context.p0DataIndex >= forecastIdx ? [5, 5] : undefined,
                        borderColor: context => context.p0DataIndex >= forecastIdx ? '#1cc88a' : '#1f66c4'
                    }
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            title: context => context[0].label
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: {
                            color: '#000000',
                            callback: function (value) {
                                const fullLabel = this.getLabelForValue(value);
                                return fullLabel.split(' ')[0];
                            }
                        }
                    },
                    y: {
                        grid: {
                            display: true,
                            color: '#00000035',
                            lineWidth: 1
                        },
                        border: {
                            width: 1,
                            color: '#f2f1f7'
                        },
                        ticks: {
                            color: '#848aa1',
                            callback: value => (value / 100000).toFixed(1) + 'L'
                        },
                        beginAtZero: true
                    }
                }
            }
        });
    }
    function GetAIAnalyticsLandingCostTrendSelectionItems(){
        $('#lanidng-cost-trend-itemCode').html('');
        var apiData = {
            UserId: ScriptUser.USERID
        }
        $.ajax({
            url: RequestBasePath + '/Analytics/GetAIAnalyticsLandingCostTrendSelectionItems',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                if(outData.length > 0){
                    for(var i = 0; i < outData.length; i++){
                        var element = "<option value='"+ outData[i]["ItemCode"] +"'>" + outData[i]["ItemName"] + "("+ outData[i]["ItemCode"] +")</option>";
                        $('#lanidng-cost-trend-itemCode').append(element);
                    }
                    GetAIAnalyticsLandingCostTrend()
                }
                else{
                     var element = "<option value=''>No products available</option>";
                     $('#lanidng-cost-trend-itemCode').append(element);
                }
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }
    function GetAIAnalyticsLandingCostTrend(){
        var apiData = {
            UserId: ScriptUser.USERID,
            ItemCode: $('#lanidng-cost-trend-itemCode').val()
        }
        $.ajax({
            url: RequestBasePath + '/Analytics/GetAIAnalyticsLandingCostTrend',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                var lcLabels = outData["LandingCostTrendLabels"];
                var lcActual = outData["LandingCostActualData"];
                var lcForecast = outData["LandingCostForecastData"];
                initLandingCostTrendChart(lcLabels, lcActual, lcForecast)
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }
    function initLandingCostTrendChart(labels, actualData, forecastData) {
        const canvas = document.getElementById('stockStatusChart');
        if (!canvas || !labels || labels.length === 0) return;

        const ctx = canvas.getContext('2d');

        if (window.landingCostTrendChart) {
            window.landingCostTrendChart.destroy();
        }

        window.landingCostTrendChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Historical LC',
                        data: actualData,
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37, 99, 235, 0.15)',
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        borderWidth: 2,
                        tension: 0.2,
                        spanGaps: true
                    },
                    {
                        label: 'Forecast LC',
                        data: forecastData,
                        borderColor: '#16a34a',
                        backgroundColor: 'rgba(22, 163, 74, 0.15)',
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        borderWidth: 2,
                        borderDash: [6, 4],
                        tension: 0.2,
                        spanGaps: true
                    }
                ]
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#4b5563' }
                    },
                    y: {
                        beginAtZero: false,
                        grid: {
                            color: '#00000020',
                            lineWidth: 1
                        },
                        ticks: {
                            color: '#4b5563',
                            callback: value => 'Rs ' + Number(value).toLocaleString('en-IN', { maximumFractionDigits: 2 })
                        }
                    }
                }
            }
        });
    }
    $(document).on('change', '#lanidng-cost-trend-itemCode', function () {
        GetAIAnalyticsLandingCostTrend();
    });
    function GetAIAnalyticsReceivablesAging(){
        var apiData = {
            UserId: ScriptUser.USERID
        }
        $.ajax({
            url: RequestBasePath + '/Analytics/GetAIAnalyticsReceivablesAging',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                var labels = outData["AgingBucketLabels"];
                var series = outData["AgingSeries"];
                initReceivablesAgingChart(labels, series)
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }
    function initReceivablesAgingChart(labels, series) {
        const canvas = document.getElementById('agingChart');
        if (!canvas || !labels || labels.length === 0 || !series) return;

        const ctx = canvas.getContext('2d');
        const riskColors = {
            Critical: '#dc2626',
            High: '#ea580c',
            Moderate: '#d97706',
            Low: '#16a34a'
        };

        const datasets = series
            .map(s => ({
                risk: s.risk || s.Risk,
                data: s.data || s.Data || []
            }))
            .filter(s => s.risk && s.risk.toLowerCase() !== 'zero')
            .map(s => ({
                label: s.risk,
                data: s.data,
                backgroundColor: riskColors[s.risk] || '#64748b',
                borderColor: riskColors[s.risk] || '#64748b',
                borderWidth: 1,
                borderRadius: 4,
                maxBarThickness: 58,
                categoryPercentage: 0.88,
                barPercentage: 0.95
            }));

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: datasets
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: context => {
                                const value = context.raw || 0;
                                return context.dataset.label + ': Rs ' + Number(value).toLocaleString('en-IN', { maximumFractionDigits: 0 });
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        stacked: true,
                        grid: { display: false },
                        ticks: { color: '#4b5563' }
                    },
                    y: {
                        stacked: true,
                        beginAtZero: true,
                        grid: { color: '#00000020' },
                        ticks: {
                            color: '#4b5563',
                            callback: value => 'Rs ' + Number(value).toLocaleString('en-IN', { maximumFractionDigits: 0 })
                        }
                    }
                }
            }
        });
    }
    function GetAIAnalyticsReceivablesPriorityList(_OrderBy = ""){
        var apiData = {
            UserId: ScriptUser.USERID,
            OrderBy: _OrderBy
        }
        $.ajax({
            url: RequestBasePath + '/Analytics/GetAIAnalyticsReceivablesPriorityList',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                console.log(outData)
                $('#receivablesTable tbody').html('');
                if(outData.length > 0)
                {
                    for(var i = 0; i < outData.length; i++){
                        var badgeClass = "bg-secondary";
                        var actionText = "Review";
                        var actionButtonClass = "btn-outline-teal";
                        if (outData[i]["RiskLevel"] == "Critical" || outData[i]["RiskLevel"] == "High")
                        {
                            badgeClass = "bg-danger";
                            actionText = "Call";
                        }
                        else if (outData[i]["RiskLevel"] == "Moderate")
                        {
                            badgeClass = "bg-warning text-dark";
                            actionText = "Follow Up";
                        }
                        else if (outData[i]["RiskLevel"] == "Low")
                        {
                            badgeClass = "bg-success";
                            actionText = "Reminder";
                        }
                        else if (outData[i]["RiskLevel"] == "N/A")
                        {
                            badgeClass = "bg-light text-dark border";
                            actionText = "Unscored";
                            actionButtonClass = "btn-outline-secondary";
                        }

                        var element = `
                        <tr
                            data-outstanding="`+outData[i]["OutstandingAmount"]+`"
                            data-payment="`+outData[i]["ExpectedPaymentDate"]+`"
                            data-risk="`+outData[i]["RiskLevel"]+`">
                            
                            <td class="fw-semibold">`+outData[i]["CustomerName"]+` </td>
                            <td class="text-end">₹ `+outData[i]["OutstandingAmount"]+`</td>
                            <td class="text-center text-muted">
                                `+outData[i]["ExpectedPaymentDate"]+`
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill ` + badgeClass + ` risk-badge fs-6">`+outData[i]["RiskLevel"]+`</span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm ` + actionButtonClass + ` px-3 py-1">` + actionText + `</button>
                            </td>
                        </tr>
                        `;
                     $('#receivablesTable tbody').append(element)
                }
                }else{
                    $('#receivablesTable tbody').html('<tr><td colspan="5">No data found.</td></tr>');
                }
                
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }
    $(document).on('click', '.sortable-header', function(){
        var _OrderBy = $(this).attr("data-sort");
        GetAIAnalyticsReceivablesPriorityList(_OrderBy);
    });
    function convertToIndianFormat(amount) {
        if (amount >= 10000000) {
            return "₹ " + (amount / 10000000).toFixed(2).replace(/\.00$/, "") + " Cr";
        } else if (amount >= 100000) {
            return "₹ " + (amount / 100000).toFixed(2).replace(/\.00$/, "") + " L";
        }
        return "₹ " + Math.round(amount).toLocaleString("en-IN");
    }
