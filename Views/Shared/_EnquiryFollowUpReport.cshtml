             var element = "<tr class='t-row list-view-item-row'><td class='px-4 py-2' colspan='3'>No data found.</td></tr>";
              $("#enquiryfollowuphistory-table-parent-tbody").append(element);
        }
    }
    function formatDate(dateStr) {
        if (!dateStr) return "";
        const date = new Date(dateStr);
        if (isNaN(date)) return dateStr; // if invalid date string
        const day = String(date.getDate()).padStart(2, "0");
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const year = date.getFullYear();
        return `${day}-${month}-${year}`;
    }
    
    
    $('#msg-resultbox-submit').click(function (event) {
        event.stopImmediatePropagation();
        $(this).parent().parent().parent().hide();
        GetenquiryfollowupReport();
    });
    $('#msg-resultbox .popup-close-filter').on('click', function(event){
        event.stopImmediatePropagation();
        $('#msg-resultbox').hide();
        GetenquiryfollowupReport();
    });
  
    $('#btn-show-filters').on('click', function(){
        $('#pop-filterbox').show();
    });
    
    $('#pop-filterbox .popup-close-filter').on('click', function(event){
        event.stopImmediatePropagation();
        $('#pop-filterbox').hide();
    });
    
    //Common functions
    function GetDate_YYYYMMDD(val) {
        if (!val) return '';

        var d = new Date(val);
        if (isNaN(d)) return '';

        return d.getFullYear() + '-' +
            ('0' + (d.getMonth() + 1)).slice(-2) + '-' +
            ('0' + d.getDate()).slice(-2);
    }
  
</script>