<script>
    LoadSalesmanList();
    function Initialize(){
         var today = new Date().toISOString().split('T')[0];
         $('#fl-date').val(today);
    }
    InitializeFilters();
    function InitializeFilters(){
         var today = new Date().toISOString().split('T')[0];
         $('#fl-fromdate').val(today);
         $('#fl-todate').val(today);
         $('#fl-status').val(1);
         $('#fl-salesman').val(0);
         $('#fl-customer').val('');
    }
    function LoadSalesmanList(){
        var apiData = {
            CompanyId: 1,
            BranchId: $('#branch-selector').val(),
            YearCode: $('#financial-year-selector').val(),
            UserId: ScriptUser.USERID
        }

        $.ajax({
            url: RequestBasePath + '/EnquiryFollowUp/GetSalesmanLookup',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                RenderSalesmanList(outData["SalesMan"]);
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }
    function RenderSalesmanList(data){
        console.log(data);
        $('#fl-salesman').html('<option value="0">All</option>')
        for(var i = 0; i < data.length; i++){
            var element = "<option value='"+ data[i]["SalesManId"] +"'>"+ data[i]["SalesMan"] +"</option>";
            $('#fl-salesman').append(element)
        }
    }
    $('#pop-filterbox-clear').on('click', function(){
       InitializeFilters();
    });
    $('#pop-filterbox-submit').on('click', function(){
        GetEnquiryFollowUpSummaryReport();
    });
    
    function showLoader() {
        $('#enquiryfollowup-loader').css('display', 'flex');
    }
    function hideLoader() {
        $('#enquiryfollowup-loader').css('display', 'none');
    }
    GetEnquiryFollowUpSummaryReport();
   
    $(document).on("click", ".basefilter-btn", function(){
        $(".basefilter-btn").removeClass("active");
        $(this).addClass("active");
        GetEnquiryFollowUpSummaryReport();
    });
    function GetEnquiryFollowUpSummaryReport() {
        var tbody = $("#enquiryfollowup-base-table-parent tbody");
        tbody.empty();
        var tbodyhistory = $("#enquiryfollowuphistory-table-parent-tbody");
        tbodyhistory.empty();
        showLoader();
       
        var _FromDate = GetDate_YYYYMMDD($('#fl-fromdate').val());
        var _ToDate = GetDate_YYYYMMDD($('#fl-todate').val());
        var _Status = $('#fl-status').val();
        var _TypeId = $(".basefilter-btn.active").data("filter-type");
        var _Salesman = $("#fl-salesman").val();
        var _Customer = $("#fl-customer").val();
        //10000761
        var apiData = {
            BranchId: $('#branch-selector').val(),
            YearCode: $('#financial-year-selector').val(),
            salesmanorrepcode: _Salesman,
            TypeId: _TypeId,
            countlist: 0,
            sfromDate: _FromDate,
            stoDate: _ToDate,
            CustomerCode: 0,
            issearch: 0,
            statusid: _Status,
            custname: _Customer
        }

        $.ajax({
            url: RequestBasePath + '/EnquiryFollowUp/GetEnquiryFollowUpSummaryReport',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                hideLoader();
                RenderEnquiryFollowUpSummaryReport(outData);
                $('#pop-filterbox').hide();
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }
    function RenderEnquiryFollowUpSummaryReport(data){
        var tbody = $("#enquiryfollowup-base-table-parent tbody");
        tbody.empty();

        var tbodydetailed = $("#enquiryfollowup-table-parent tbody");
        tbodydetailed.empty();
        
        if(data != null && data.length > 0){
            for(var i = 0; i < data.length; i++){
               var element = "<tr class='summary-row t-row list-view-item-row' data-orderno='" + data[i]["orderno"] +"' data-branchid='" + data[i]["branchid"] +"' data-yearcode='" + data[i]["yearcode"] +"'><td class='px-4 py-2' style='white-space: nowrap;'>" + data[i]["entrydate"] + "</td><td class='px-4 py-2 customer-col-style' ><div><div class='summary-customer-name'>" + data[i]["customer"] + "</div><div class='summary-customer-address'>" + data[i]["address1"] + "</div><div class='summary-customer-status'>" + data[i]["enquirystatus"] + "</div><div class='summary-customer-status'>Next Followed By: <span style='color:red;'>" + data[i]["assignedto"] + "</span<</div></div></td><td class='px-4 py-2' style='white-space: nowrap;'><div><div class='summary-details-enqno'>Enq.No: " + data[i]["orderno"] + "</div><div class='summary-customer-billamt'>BL: " + data[i]["billamount"] + "</div><div class='summary-customer-nextfollowup'>Next Followup: " + data[i]["followupdate"] + "</div></div></td></tr>";
               $("#enquiryfollowup-base-table-parent tbody").append(element);
            }

            var $rows = $("#enquiryfollowup-base-table-parent tbody tr");
            if ($rows.length > 0 && data.length) {
                $rows.first().trigger("click");
            }
        }
        else
        {
             var element = "<tr class='t-row list-view-item-row'><td class='px-4 py-2' colspan='3'>No data found.</td></tr>";
               $("#enquiryfollowup-base-table-parent tbody").append(element);
        }
    }
    $(document).on("click", ".summary-row", function () {
        $(".summary-row").removeClass("summary-row-selected");
        $(this).addClass("summary-row-selected");
        var _OrderNo = $(this).attr('data-orderno');
        var _BranchId = $(this).attr('data-branchid');
        var _YearCode = $(this).attr('data-yearcode');
        GetEnquiryFollowUpHistory(_OrderNo, _BranchId, _YearCode);
    });
     
    function GetEnquiryFollowUpHistory(_OrderNo, _BranchId, _YearCode) {
        var tbodyhistory = $("#enquiryfollowuphistory-table-parent-tbody");
        tbodyhistory.empty();

        var apiData = {
            BranchId: _BranchId,
            YearCode: _YearCode,
            orderNo :_OrderNo
        }

        $.ajax({
            url: RequestBasePath + '/EnquiryFollowUp/GetEnquiryFollowUpHistoryReport',
            type: 'Post',
            data: { strdata: JSON.stringify(apiData) },
            success: function (data) {
                var outData = JSON.parse(data);
                hideLoader();
                RenderEnquiryFollowUpHistoryReport(outData);
                $('#pop-filterbox').hide();
            },
            error: function (jqXHR, exception) {
                console.log(jqXHR);
                console.log(exception);
            },
        });
    }
    function RenderEnquiryFollowUpHistoryReport(data){
       
        var tbodydetailed = $("#enquiryfollowuphistory-table-parent-tbody");
        tbodydetailed.empty();
        if(data != null && data.length > 0){
            for(var i = 0; i < data.length; i++){
                if(data[i]["id"] == "B"){
                     var element = `<tr class='hover:bg-gray-50 history-item'>
                                <td class='px-4 py-2'>
                                    <div class='history-item-top-section'>
                                        <div class='history-top-img'><img src='Images/user.png' alt='user image' /></div>
                                        <div class='history-top-content'>Update Followup Enquiry by <strong>`+ data[i]["donebyuser"] +` on `+ data[i]["createddatetimeformat"] +`</strong></div>
                                    </div>
                                    <div class='history-item-mid-section'>
                                        <table class="min-w-full divide-y divide-gray-200">
                                            <tbody class="divide-y divide-gray-100">
                                                <tr class="t-row list-view-item-row hover:bg-gray-50">
                                                    <td class="px-4 py-2">Follow Up Date</td>
                                                    <td class="px-4 py-2">`+ data[i]["followupdate"]+`</td>
                                                </tr>
                                                <tr class="t-row list-view-item-row hover:bg-gray-50">
                                                    <td class="px-4 py-2">Follow Up Status</td>
                                                    <td class="px-4 py-2">`+ data[i]["followupstatus"]+`</td>
                                                </tr>
                                                <tr class="t-row list-view-item-row hover:bg-gray-50">
                                                    <td class="px-4 py-2">Follow Up Type</td>
                                                    <td class="px-4 py-2">`+ data[i]["followuptype"]+`</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    `;
                                    if(data[i]["remarks"] != "" && data[i]["remarks"] != NaN){
                                        element += `<div class="history-item-comment-section">
                                        `+ data[i]["remarks"] +`
