                                    }
                                    if(data[i]["photo1"] != ""){
                                        element += `<div class="history-img-section">
                                            <img src="`+data[i]["photo1"]+`" />
                                         </div>`;
                                    }
                                element += `</td>
                            </tr>`;
                             $("#enquiryfollowuphistory-table-parent-tbody").append(element);
               }
               else
               {
                   console.log(data[i]["CrmFollowUpItemListModel"])
                   console.log(data[i]["CrmFollowUpItemListModel"].length)
                   var element = `<tr class='hover:bg-gray-50 history-item'>
                                <td class='px-4 py-2'>
                                    <div class='history-item-top-section'>
                                        <div class='history-top-img'><img src='Images/user.png' alt='user image' /></div>
                                        <div class='history-top-content'>Enquiry added <strong>on `+ data[i]["createddatetimeformat"] +`</strong></div>
                                    </div>
                                    <div class='history-item-mid-section'>
                                        <div><strong>Items</strong></div>
                                        <div class="history-enqitem-container">`;
                                            for(var j = 0; j < data[i]["CrmFollowUpItemListModel"].length; j++){
                                                console.log(data[i]["CrmFollowUpItemListModel"][j])
                                            element += `<div class="enqitem">
                                                <div><strong>`+data[i]["CrmFollowUpItemListModel"][j]["itemname"]+`</strong></div>
                                                <div class="enq-item-detail-tile">
                                                    <div>
                                                        <div class="enq-item-detail-label">Qty</div>
                                                        <div class="enq-item-detail-val-qty"><strong>`+data[i]["CrmFollowUpItemListModel"][j]["qty"]+`</strong></div>
                                                    </div>
                                                    <div>
                                                        <div class="enq-item-detail-label">Rate</div>
                                                        <div class="enq-item-detail-val-rate"><strong>`+data[i]["CrmFollowUpItemListModel"][j]["rate"]+`</strong></div>
                                                    </div>
                                                    <div>
                                                        <div class="enq-item-detail-label">Rate</div>
                                                        <div class="enq-item-detail-val-total"><strong>`+data[i]["CrmFollowUpItemListModel"][j]["nettotal"]+`</strong></div>
                                                    </div>
