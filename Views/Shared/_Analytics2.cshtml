<style>
    :root {
        --bg: #f4f6fb;
        --card: #ffffff;
        --text: #1f2a37;
        --muted: #6b7280;
        --line: #e7ebf3;
        --blue: #2f7cf6;
        --blue-2: #69a7ff;
        --green: #22c55e;
        --amber: #f59e0b;
        --red: #ef4444;
        --shadow: 0 10px 30px rgba(31,42,55,.08);
        --radius: 14px;
    }

    * {
        box-sizing: border-box
    }

    body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Helvetica Neue", Helvetica, "Noto Sans", "Liberation Sans", sans-serif;
        color: var(--text);
        background: radial-gradient(900px 450px at 20% 10%, #e9f1ff 0%, rgba(233,241,255,0) 70%), radial-gradient(900px 450px at 90% 0%, #efeaff 0%, rgba(239,234,255,0) 60%), var(--bg);
    }

    .wrap {
        --max-width: 1180px;
        margin: 26px auto;
        padding: 0 18px 34px;
    }

   
    .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
    }

    .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .card-pad {
        padding: 14px 16px;
    }

    /* ---- Top summary cards ---- */
    .summary {
        grid-column: span 3;
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 86px;
    }

        .summary .label {
            font-size: 13px;
            font-weight: 700;
            color: #3b4556;
            opacity: .9;
        }

        .summary .value {
            display: flex;
            align-items: baseline;
            gap: 10px;
            margin-top: 2px;
        }

        .summary .amt {
            font-size: 22px;
            font-weight: 800;
            letter-spacing: .2px;
        }

        .summary .sub {
            font-size: 12px;
            color: var(--muted);
            display: flex;
            gap: 6px;
            align-items: center;
        }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        border: 1px solid var(--line);
        background: #fbfcff;
    }

        .pill.green {
            color: #0b7a2a;
            background: #eafaf0;
            border-color: #c9f1d6;
        }

        .pill.amber {
            color: #8a5a00;
            background: #fff6e6;
            border-color: #ffe2b4;
        }

        .pill.red {
            color: #8a1111;
            background: #ffeaea;
            border-color: #ffc2c2;
        }

    /* ---- Section headers ---- */
    .card-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 12px 16px;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
    }

        .card-head h3 {
            margin: 0;
            font-size: 14px;
            font-weight: 800;
            color: #2b3443;
        }

        .card-head .meta {
            font-size: 12px;
            color: var(--muted);
            font-weight: 600;
        }

    /* ---- Layout blocks ---- */
    .trend {
        grid-column: span 7;
    }

    .stock {
        grid-column: span 5;
    }

    .aging {
        grid-column: span 7;
    }

    .insights {
        grid-column: span 5;
    }

    .table {
        grid-column: span 12;
    }

    /* ---- Chart helpers ---- */
    .chart {
        padding: 10px 12px 12px;
    }

    .svg {
        width: 100%;
        height: auto;
        display: block;
    }

    .legend {
        display: flex;
        gap: 14px;
        align-items: center;
        padding: 0 16px 12px;
        color: var(--muted);
        font-size: 12px;
        font-weight: 600;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 3px;
        display: inline-block;
        margin-right: 6px;
    }

    /* ---- Insights list ---- */
    .insight-list {
        padding: 12px 16px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .insight {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 10px 12px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: #fbfcff;
    }

    .warn {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        background: #fff6e6;
        border: 1px solid #ffe2b4;
        color: #8a5a00;
        font-weight: 900;
        flex: 0 0 auto;
    }

    .insight p {
        margin: 2px 0 0;
        font-size: 13px;
        color: #3b4556;
        font-weight: 650;
    }

    /* ---- Table ---- */
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    thead th {
        text-align: left;
        padding: 12px 14px;
        color: #3b4556;
        font-weight: 800;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
    }

    tbody td {
        padding: 11px 14px;
        border-bottom: 1px solid var(--line);
        color: #2b3443;
        font-weight: 650;
    }

    tbody tr:hover td {
        background: #fbfcff;
    }

    .risk {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
        color: #3b4556;
    }

        .risk .r-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: var(--muted);
        }

        .risk.high .r-dot {
            background: var(--red);
        }

        .risk.med .r-dot {
            background: var(--amber);
        }

        .risk.low .r-dot {
            background: var(--green);
        }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 12px;
        border-radius: 10px;
        border: 1px solid var(--line);
        background: #f7faff;
        font-weight: 800;
        font-size: 12px;
        color: #1f3b7a;
        cursor: pointer;
        user-select: none;
    }

        .btn.call {
            background: #eaf2ff;
            border-color: #cfe0ff;
            color: #1b4fbf;
        }

        .btn.follow {
            background: #fff6e6;
            border-color: #ffe2b4;
            color: #8a5a00;
        }

        .btn.remind {
            background: #eafaf0;
            border-color: #c9f1d6;
            color: #0b7a2a;
        }

    /* ---- Responsiveness ---- */
    @@media (max-width: 1020px) {
        .summary

    {
        grid-column: span 6;
    }

    .trend, .aging {
        grid-column: span 12;
    }

    .stock, .insights {
        grid-column: span 12;
    }

    }
    @@media (max-width: 560px) {
        .summary

    {
        grid-column: span 12;
    }

    .title {
        font-size: 24px;
    }

    thead {
        display: none;
    }

    tbody tr {
        display: grid;
        grid-template-columns: 1fr;
    }

    tbody td {
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

        tbody td::before {
            content: attr(data-label);
            color: var(--muted);
            font-weight: 800;
        }

    }
</style>

